# Local Postgres connection (create a DB called job_copilot first)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/job_copilot?schema=public"

# Your Anthropic API key — get one at https://console.anthropic.com
# This stays on the SERVER only. Never expose it in client code.
ANTHROPIC_API_KEY="sk-ant-..."

# Model used for tailoring. Check current names at:
# https://docs.claude.com/en/docs/about-claude/models
TAILOR_MODEL="claude-sonnet-4-6"
